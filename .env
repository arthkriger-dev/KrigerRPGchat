# API_TYPE: anthropic | kobold | openai | groq
API_TYPE=anthropic

# Para Anthropic:
API_KEY=sk-ant-COLOCA_AQUI

# Para KoboldAI local (deixa API_KEY vazio):
# API_TYPE=kobold
# API_URL=http://127.0.0.1:5001

# Para Groq:
# API_TYPE=groq
# API_KEY=gsk_XXXXX
# API_URL=https://api.groq.com/openai

# Para OpenAI:
# API_TYPE=openai
# API_KEY=sk-XXXXX
# API_URL=https://api.openai.com

MODEL=claude-haiku-4-5
# Para Groq: llama-3.3-70b-versatile
# Para KoboldAI: ignora este campo

TEMPERATURE=0.7
PORT=3000

# Para KoboldAI — limitar context window (tokens)
MAX_CONTEXT=4096

# Número de mensagens do histórico a enviar (reduzir para poupar tokens)
# Anthropic/Groq: 20 | KoboldAI: 8
HISTORY_LIMIT=20
